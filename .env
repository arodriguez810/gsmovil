APP_NAME="General de Seguros"
APP_ENV=local
APP_KEY=base64:fYZt2acMwZiJ0iNX16WHc35kZ0VX1klzm1PYVRkJ9o4=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# =======================================================
# WEBVIEW — URL Y COMPORTAMIENTO
# =======================================================

# URL que cargará el WebView al abrir la app.
# Puede ser una URL externa (HTTPS recomendado) o dejar vacío
# para usar el router interno de Laravel.
WEBVIEW_URL=https://qa.gsweb.com.do/login

# Texto que se añade al User Agent.
# Útil para que tu servidor detecte que la petición viene de la app.
# Detección en PHP: str_contains(request()->userAgent(), 'GSMovilApp')
WEBVIEW_UA_SUFFIX=GSMovilApp/1.0

# =======================================================
# APP — DATOS PARA PUBLICACIÓN EN TIENDAS
# =======================================================

# Identificador único del paquete de la app (com.empresa.nombreapp)
# ⚠️  NO cambiar después de publicar — rompería las actualizaciones.
NATIVEPHP_APP_ID=com.gsmovil.app

# Versión visible para el usuario en la tienda (ejemplo: 1.0.0, 2.1.3)
NATIVEPHP_APP_VERSION=1.0.1

# Número de versión interno — DEBE aumentar en cada nueva versión publicada.
# Play Store y App Store lo usan para verificar que es una actualización.
NATIVEPHP_APP_VERSION_CODE=2

# =======================================================
# DEEP LINKS — abrir la app desde un link externo
# =======================================================

# Scheme para links del tipo: gsmovil://ruta/de/la/app
NATIVEPHP_DEEPLINK_SCHEME=gsmovil

# Dominio para App Links (Android) y Universal Links (iOS).
# Permite que https://tudominio.com/ruta abra la app directamente.
NATIVEPHP_DEEPLINK_HOST=tudominio.com

# =======================================================
# ANDROID — RUTAS DEL ENTORNO DE BUILD
# =======================================================

# Ruta al JDK que usa Gradle (viene con Android Studio).
NATIVEPHP_GRADLE_PATH="C:\\Program Files\\Android\\Android Studio\\jbr"

# Ruta al Android SDK.
NATIVEPHP_ANDROID_SDK_LOCATION=C:\\AndroidSDK

# Ruta al binario del emulador de Android (emulator.exe dentro del SDK)
ANDROID_EMULATOR=C:\\AndroidSDK\\emulator\\emulator.exe

# Ruta a 7-Zip (necesario para empaquetar en Windows).
NATIVEPHP_7ZIP_LOCATION="C:\\Program Files\\7-Zip\\7z.exe"

# =======================================================
# iOS / macOS — CERTIFICADOS Y APP STORE CONNECT
# =======================================================

# Tu Team ID de Apple Developer.
# Lo encuentras en: developer.apple.com → Account → Membership Details
NATIVEPHP_DEVELOPMENT_TEAM=

# Claves de la API de App Store Connect (para publicar automáticamente).
# Las creas en: appstoreconnect.apple.com → Users and Access → Integrations → App Store Connect API
APP_STORE_API_KEY=
APP_STORE_API_KEY_ID=
APP_STORE_API_ISSUER_ID=
APP_STORE_APP_NAME="General de Seguros"
